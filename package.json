{
  "name": "tg11-cyberpunk-pack",
  "displayName": "TG11 Cyberpunk Pack",
  "description": "A cyberpunk VS Code theme pack with vivid comment tag and symbol highlighting injections across many languages.",
  "version": "0.0.3",
  "publisher": "TrentonGage11",
  "license": "UNLICENSED",
  "author": {
    "name": "TrentonGage11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tg11-org/vsct-cyberpunk.git"
  },
  "homepage": "https://github.com/tg11-org/vsct-cyberpunk#readme",
  "bugs": {
    "url": "https://github.com/tg11-org/vsct-cyberpunk/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Themes"],
  "keywords": ["theme", "color-theme", "cyberpunk", "dark", "comments", "syntax-highlighting", "todo", "tcl", "python", "cpp", "javascript"],
  "galleryBanner": {
    "color": "#0f1513",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "tg11-cyberpunk",
        "uiTheme": "vs-dark",
        "path": "./themes/tg11-cyberpunk-color-theme.json"
      }
    ],
    "grammars": [
      {
        "scopeName": "tg11-cyberpunk.comment.injection",
        "path": "./syntaxes/tg11-cyberpunk-comment-injection.tmLanguage.json",
        "injectTo": [
          "source.ada",
          "source.apex",
          "source.asm",
          "source.batchfile",
          "source.c",
          "source.clojure",
          "source.coffee",
          "source.csharp",
          "source.cpp",
          "source.css",
          "source.css.less",
          "source.css.scss",
          "source.d",
          "source.dart",
          "source.diff",
          "source.dockerfile",
          "source.elixir",
          "source.elm",
          "source.erlang",
          "source.fsharp",
          "source.fortran",
          "source.go",
          "source.graphql",
          "source.groovy",
          "source.haskell",
          "source.haxe",
          "source.ini",
          "source.java",
          "source.js",
          "source.jsx",
          "source.json",
          "source.julia",
          "source.kotlin",
          "source.less",
          "source.lisp",
          "source.lua",
          "source.makefile",
          "source.matlab",
          "source.nix",
          "source.ocaml",
          "source.objc",
          "source.objcpp",
          "source.pascal",
          "source.perl",
          "source.php",
          "source.powershell",
          "source.proto",
          "source.python",
          "source.r",
          "source.raku",
          "source.reason",
          "source.ruby",
          "source.rust",
          "source.sass",
          "source.scala",
          "source.shell",
          "source.solidity",
          "source.sql",
          "source.svelte",
          "source.swift",
          "source.tcl",
          "source.toml",
          "source.ts",
          "source.tsx",
          "source.verilog",
          "source.vhdl",
          "source.viml",
          "source.vue",
          "source.yaml",
          "source.zig",
          "text.html.basic",
          "text.html.markdown",
          "text.pug",
          "text.tex.latex",
          "text.xml"
        ]
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "release:github": "node ./scripts/publish-github-release.mjs",
    "release:package:github": "npm run package && npm run release:github"
  },
  "devDependencies": {
    "vsce": "2.15.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}
