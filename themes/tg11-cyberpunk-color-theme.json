{
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    "editor.background": "#0f1513",
    "editor.foreground": "#dbf8eb",
    "editorCursor.foreground": "#ff7a00",
    "editor.selectionBackground": "#1e3a2f",
    "editor.lineHighlightBackground": "#16201d",
    "editorLineNumber.foreground": "#2b91af",
    "editorLineNumber.activeForeground": "#2b91af",
    "editorInlayHint.background": "#3e3021",
    "editorInlayHint.foreground": "#9b7b5c",
    "editorWhitespace.foreground": "#204852",
    "sideBar.background": "#0c1914",
    "sideBar.foreground": "#9ac0ad",
    "activityBar.background": "#0c1914",
    "activityBar.foreground": "#dbf8eb",
    "activityBarBadge.background": "#ff7a00",
    "activityBarBadge.foreground": "#0f1513",
    "statusBar.background": "#0c1914",
    "statusBar.foreground": "#9ac0ad",
    "statusBar.debuggingBackground": "#ff4d64",
    "titleBar.activeBackground": "#0c1914",
    "titleBar.activeForeground": "#dbf8eb",
    "tab.activeBackground": "#0f1513",
    "tab.activeForeground": "#dbf8eb",
    "tab.inactiveBackground": "#0c1914",
    "tab.inactiveForeground": "#9ac9ad",
    "terminal.background": "#0f1513",
    "terminal.foreground": "#dbf8eb",
    "terminal.inactiveSelectionBackground": "#3A3D41",
    "focusBorder": "#ff7a00",
    "button.background": "#39cb83",
    "button.foreground": "#0f1513",
    "menu.background": "#303031",
    "menu.foreground": "#CCCCCC",
    "ports.iconRunningProcessForeground": "#369432"
  },
  "tokenColors": [
    {
      "name": "Keyword & Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.operator.noexcept"
      ],
      "settings": {
        "foreground": "#ff7a00"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#d100ff"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#28a7ff"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#ff4d64",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars",
        "source.powershell variable.other.member",
        "entity.name.operator.custom-literal"
      ],
      "settings": {
        "foreground": "#7a63ff"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.namespace",
        "entity.other.attribute",
        "entity.name.scope-resolution",
        "entity.name.class",
        "storage.type.numeric.go",
        "storage.type.byte.go",
        "storage.type.boolean.go",
        "storage.type.string.go",
        "storage.type.uintptr.go",
        "storage.type.error.go",
        "storage.type.rune.go",
        "storage.type.cs",
        "storage.type.generic.cs",
        "storage.type.modifier.cs",
        "storage.type.variable.cs",
        "storage.type.annotation.java",
        "storage.type.generic.java",
        "storage.type.java",
        "storage.type.object.array.java",
        "storage.type.primitive.array.java",
        "storage.type.primitive.java",
        "storage.type.token.java",
        "storage.type.groovy",
        "storage.type.annotation.groovy",
        "storage.type.parameters.groovy",
        "storage.type.generic.groovy",
        "storage.type.object.array.groovy",
        "storage.type.primitive.array.groovy",
        "storage.type.primitive.groovy"
      ],
      "settings": {
        "foreground": "#ff3f57"
      }
    },
    {
      "name": "Variables & Properties",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.property",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#dbf8eb"
      }
    },
    {
      "name": "Keys (JSON/Object)",
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#ff7a00"
      }
    },
    {
      "name": "Tags (HTML/ML)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff3f57"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#7a63ff"
      }
    },
    {
      "name": "Operators & Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#9ac0ad"
      }
    },
    {
      "name": "Regular expression",
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#646695"
      }
    },
    {
      "name": "Regular expression groups",
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.group.assertion.regexp",
        "punctuation.definition.character-class.regexp",
        "punctuation.character.set.begin.regexp",
        "punctuation.character.set.end.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "Regular expression classes",
      "scope": [
        "constant.character.character-class.regexp",
        "constant.other.character-class.set.regexp",
        "constant.other.character-class.regexp",
        "constant.character.set.regexp"
      ],
      "settings": {
        "foreground": "#d16969"
      }
    },
    {
      "name": "Regular expression anchor",
      "scope": [
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#dcdcaa"
      }
    },
    {
      "name": "Regular expression quantifier",
      "scope": [
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#d7ba7d"
      }
    },
    {
      "name": "invalid",
      "scope": "invalid",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": {
        "foreground": "#6A9955"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#6796e6"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "name": "Custom Comments Special Notes",
      "scope": "keyword.control.comment.special.note",
      "settings": {
        "foreground": "#f872fc"
      }
    },
    {
      "name": "Custom Comments Special Todo",
      "scope": "keyword.control.comment.special.todo",
      "settings": {
        "foreground": "#ffa200"
      }
    },
    {
      "name": "Custom Comments Special Fix Me",
      "scope": "keyword.control.comment.special.fixme",
      "settings": {
        "foreground": "#ff2a00"
      }
    },
    {
      "name": "Custom Comments Special Hack",
      "scope": "keyword.control.comment.special.hack",
      "settings": {
        "foreground": "#fff700"
      }
    },
    {
      "name": "Custom Comments Special Bug",
      "scope": "keyword.control.comment.special.bug",
      "settings": {
        "foreground": "#00ff6e"
      }
    },
    {
      "name": "Custom Comments Special Danger",
      "scope": "keyword.control.comment.special.xxx",
      "settings": {
        "foreground": "#ffa200"
      }
    },
    {
      "name": "Custom Comments Special Note Bene",
      "scope": "keyword.control.comment.special.nb",
      "settings": {
        "foreground": "#ee00ff"
      }
    },
    {
      "name": "Custom Comments Symbol Tilde",
      "scope": "keyword.control.comment.symbol.tilde",
      "settings": {
        "foreground": "#00FFCC"
      }
    },
    {
      "name": "Custom Comments Symbol Exclamation",
      "scope": "keyword.control.comment.symbol.exclamation",
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "name": "Custom Comments Symbol At",
      "scope": "keyword.control.comment.symbol.at",
      "settings": {
        "foreground": "#fff700"
      }
    },
    {
      "name": "Custom Comments Symbol #",
      "scope": "keyword.control.comment.symbol.pound",
      "settings": {
        "foreground": "#d48686"
      }
    },
    {
      "name": "Custom Comments Symbol Dollar Sign",
      "scope": "keyword.control.comment.symbol.cash",
      "settings": {
        "foreground": "#00ff00"
      }
    },
    {
      "name": "Custom Comments Symbol Percentage",
      "scope": "keyword.control.comment.symbol.percent",
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Custom Comments Symbol Caret",
      "scope": "keyword.control.comment.symbol.caret",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "name": "Custom Comments Symbol Ampersand",
      "scope": "keyword.control.comment.symbol.ampersand",
      "settings": {
        "foreground": "#d2a1fa"
      }
    },
    {
      "name": "Custom Comments Symbol List",
      "scope": [
        "keyword.control.comment.symbol.asterisk",
        "keyword.control.comment.symbol.minus",
        "keyword.control.comment.symbol.plus",
        "keyword.control.comment.symbol.equals",
        "keyword.control.comment.symbol.multiply",
        "keyword.control.comment.symbol.divide",
        "keyword.control.comment.symbol.bullet",
        "keyword.control.comment.symbol.bullet-sharp"
      ],
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "name": "Custom Comments Symbol Drawing",
      "scope": [
        "keyword.control.comment.symbol.pipe",
        "keyword.control.comment.symbol.colon",
        "keyword.control.comment.symbol.semicolon",
        "keyword.control.comment.symbol.broken-pipe",
        "keyword.control.comment.symbol.bdc-horizontal",
        "keyword.control.comment.symbol.bdc-vertical",
        "keyword.control.comment.symbol.bdc-down-right",
        "keyword.control.comment.symbol.bdc-down-left",
        "keyword.control.comment.symbol.bdc-up-right",
        "keyword.control.comment.symbol.bdc-up-left",
        "keyword.control.comment.symbol.bdc-vertical-right",
        "keyword.control.comment.symbol.bdc-vertical-left",
        "keyword.control.comment.symbol.bdc-horizontal-down",
        "keyword.control.comment.symbol.bdc-horizontal-up",
        "keyword.control.comment.symbol.bdc-vertical-horizontal",
        "keyword.control.comment.symbol.bdc-down-right-arc",
        "keyword.control.comment.symbol.bdc-down-left-arc",
        "keyword.control.comment.symbol.bdc-up-left-arc",
        "keyword.control.comment.symbol.bdc-up-right-arc"
      ],
      "settings": {
        "foreground": "#565656"
      }
    },
    {
      "name": "Custom Comments Symbol >",
      "scope": "keyword.control.comment.symbol.greaterthan",
      "settings": {
        "foreground": "#a7a7a7"
      }
    },
    {
      "name": "Custom Comments Symbol ?",
      "scope": "keyword.control.comment.symbol.question",
      "settings": {
        "foreground": "#3ed03e"
      }
    },
    {
      "name": "Custom Comments Symbol Backslash",
      "scope": "keyword.control.comment.symbol.backslash",
      "settings": {
        "foreground": "#669988"
      }
    },
    {
      "name": "Custom Comments Symbol <",
      "scope": "keyword.control.comment.symbol.lessthan",
      "settings": {
        "foreground": "#996688"
      }
    },
    {
      "name": "Custom Comments Symbol Grave",
      "scope": "keyword.control.comment.symbol.grave",
      "settings": {
        "foreground": "#343434"
      }
    },
    {
      "name": "Custom Comments Symbol Section Sign",
      "scope": "keyword.control.comment.symbol.section",
      "settings": {
        "foreground": "#abcabc"
      }
    },
    {
      "name": "Custom Comments Symbol Pilcrow",
      "scope": "keyword.control.comment.symbol.pilcrow",
      "settings": {
        "foreground": "#ccff99"
      }
    },
    {
      "name": "Custom Comments Symbol Currency Sign",
      "scope": "keyword.control.comment.symbol.generic",
      "settings": {
        "foreground": "#ff00ff"
      }
    },
    {
      "name": "Custom Comments Symbol Quotes",
      "scope": [
        "keyword.control.comment.symbol.single-right-pointing-angle-quote",
        "keyword.control.comment.symbol.single-left-pointing-angle-quote",
        "keyword.control.comment.symbol.double-right-pointing-angle-quote",
        "keyword.control.comment.symbol.double-left-pointing-angle-quote"
      ],
      "settings": {
        "foreground": "#aa33aa"
      }
    }
  ]
}
